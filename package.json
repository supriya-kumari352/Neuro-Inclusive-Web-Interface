{
  "name": "neuro-inclusive-web",
  "private": true,
  "workspaces": [
    "server",
    "extension"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace server",
    "dev:extension": "npm run dev --workspace extension",
    "build:extension": "npm run build --workspace extension",
    "build:server": "npm run build --workspace server",
    "eval": "node scripts/evaluate.mjs",
    "smoke-test": "node scripts/smoke-test.mjs",
    "test:cognitive-load": "node --import tsx tests/test-cognitive-load.ts",
    "test:data-structures": "node --import tsx tests/test-data-structures.ts",
    "test:profiles": "node --import tsx tests/test-profiles.ts",
    "test:fallbacks": "node --import tsx tests/test-fallbacks.ts",
    "test:unit": "npm run test:cognitive-load && npm run test:data-structures && npm run test:profiles && npm run test:fallbacks",
    "test:api": "node --import tsx tests/test-api.ts",
    "test": "npm run test:unit"
  }
}
